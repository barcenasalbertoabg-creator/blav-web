# Copia este archivo como .env.local y rellena los valores

# Obtén el Project ID en: https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=tu-project-id-aqui

# Nombre del dataset (por defecto "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Token para el script de migración (sólo necesario una vez)
# Créalo en: sanity.io/manage → tu proyecto → API → Tokens → Add API token
# Permisos: Editor
SANITY_API_TOKEN=tu-token-aqui
